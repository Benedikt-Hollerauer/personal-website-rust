POSTGRES_USER=backend
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=backend

JWT_SECRET=change_me_very_long_random_secret_key

# reCAPTCHA v3 — get both keys at https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key

# Mail account for the self-hosted mailserver
# Must match the account created via: setup email add contact@your-domain.com
SMTP_USER=contact@your-domain.com
SMTP_PASSWORD=your_smtp_password_here

APP_HOST=https://your-domain.com

# Social profile links (optional — defaults are already set in frontend code)
VITE_LINK_GITHUB=https://github.com/benedikt-hollerauer
VITE_LINK_INSTAGRAM=https://instagram.com/bene.hl
VITE_LINK_LINKEDIN=https://www.linkedin.com/in/benedikt-hollerauer
VITE_LINK_LINKEDIN_SKILLS=https://www.linkedin.com/in/benedikt-hollerauer/details/skills
